# Copiá este archivo como ".env" (sin .example) y completá los valores.

# OBLIGATORIO: la MISMA cadena de conexión a MongoDB que usa la app en Render.
# La encontrás en Render → tu servicio → Environment → MONGODB_URI.
MONGODB_URI=

# OPCIONALES (podés dejarlos como están)
# Puerto del panel de control web (QR / estado / prueba)
WWEBJS_PORT=3100
# Carpeta donde se guarda la sesión de WhatsApp (para no re-escanear el QR)
# WWEBJS_DATA_PATH=./.wwebjs_auth
# Ruta a un Chrome/Chromium ya instalado (si no, usa el que trae whatsapp-web.js)
# CHROMIUM_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
# Espera en milisegundos entre un mensaje y el siguiente
# WWEBJS_DELAY_MS=3000
