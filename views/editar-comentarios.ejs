<%- include('partials/header') %>
<h1>Editar Comentarios</h1>

<div class="alert alert-info">
  Solo se puede editar el campo <strong>Comentarios</strong>. Disponible hasta 1 día después del registro de REGULADA, con un máximo de 2 modificaciones.
</div>

<!-- Datos del registro (solo lectura) -->
<div class="card mb-3">
  <div class="card-body">
    <div class="row mb-2">
      <div class="col-md-3"><strong>ID Ticket:</strong> <%= registro.idTicket %></div>
      <div class="col-md-3"><strong>Fecha:</strong> <%= registro.fecha %></div>
      <div class="col-md-3"><strong>Usuario:</strong> <%= registro.usuario %></div>
      <div class="col-md-3"><strong>Pesada Para:</strong> <%= registro.pesadaPara %></div>
    </div>
    <div class="row">
      <div class="col-md-3"><strong>Campo:</strong> <%= registro.campo || '-' %></div>
      <div class="col-md-3"><strong>Grano:</strong> <%= registro.grano || '-' %></div>
      <div class="col-md-3"><strong>Lote:</strong> <%= Array.isArray(registro.lote) ? (registro.lote.join(', ') || '-') : (registro.lote || '-') %></div>
      <div class="col-md-3"><strong>Patentes:</strong> <%= registro.patentes || '-' %></div>
    </div>
  </div>
</div>

<!-- Formulario: único campo editable -->
<form action="/editar-comentarios/<%= registro._id %>?_method=PUT" method="post" class="mt-3" autocomplete="off">
  <input type="hidden" name="_method" value="PUT">

  <div class="form-group mt-2">
    <label>Comentarios</label>
    <textarea name="comentarios" class="form-control" rows="5"><%= registro.comentarios || '' %></textarea>
  </div>

  <button type="submit" class="btn btn-primary mt-3">Guardar Comentarios</button>
  <a href="/tabla" class="btn btn-outline-secondary mt-3">Cancelar</a>
</form>

<%- include('partials/footer') %>
