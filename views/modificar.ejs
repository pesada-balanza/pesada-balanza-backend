<%- include('partials/header') %>
<h1>Modificar Registro</h1>

<div class="alert alert-info">
  Los campos <strong>ID Ticket, Fecha, Usuario, Pesada Para, Campo, Grano y Lote</strong> no son editables.
</div>

<!-- Campos NO editables: solo lectura -->
<div class="card mb-3">
  <div class="card-body">
    <div class="row mb-2">
      <div class="col-md-3"><strong>ID Ticket:</strong> <%= registro.idTicket %></div>
      <div class="col-md-3"><strong>Fecha:</strong> <%= registro.fecha %></div>
      <div class="col-md-3"><strong>Usuario:</strong> <%= registro.usuario %></div>
      <div class="col-md-3"><strong>Pesada Para:</strong> <%= registro.pesadaPara %></div>
    </div>
    <div class="row">
      <div class="col-md-4"><strong>Campo:</strong> <%= registro.campo || '-' %></div>
      <div class="col-md-4"><strong>Grano:</strong> <%= registro.grano || '-' %></div>
      <div class="col-md-4"><strong>Lote:</strong> <%= registro.lote || '-' %></div>
    </div>
  </div>
</div>

<!-- Formulario con campos editables -->
<form action="/modificar/<%= registro._id %>?_method=PUT" method="post" class="mt-3" autocomplete="off">
  <input type="hidden" name="_method" value="PUT">

  <div class="row">
    <div class="col-md-4 form-group">
      <label>Patentes</label>
      <input type="text" name="patentes" class="form-control" value="<%= registro.patentes || '' %>">
    </div>
    <div class="col-md-4 form-group">
      <label>Transporte</label>
      <input type="text" name="transporte" class="form-control" value="<%= registro.transporte || '' %>">
    </div>
    <div class="col-md-4 form-group">
      <label>Chofer</label>
      <input type="text" name="chofer" class="form-control" value="<%= registro.chofer || '' %>">
    </div>
  </div>

  <div class="row">
    <div class="col-md-4 form-group">
      <label>Carga para</label>
      <select name="cargaPara" class="form-control" onchange="toggleSocio()">
        <option value="AMH"   <%= registro.cargaPara === 'AMH'   ? 'selected' : '' %>>AMH</option>
        <option value="SOCIO" <%= registro.cargaPara === 'SOCIO' ? 'selected' : '' %>>SOCIO</option>
      </select>
    </div>
    <div class="col-md-4 form-group" id="socioField" style="display:<%= registro.cargaPara === 'SOCIO' ? 'block' : 'none' %>;">
      <label>Nombre del Socio</label>
      <input type="text" name="socio" class="form-control" value="<%= registro.socio || '' %>">
    </div>
  </div>

  <div class="row">
    <div class="col-md-4 form-group">
      <label>Bruto Estimado (kg)</label>
      <select name="brutoEstimado" class="form-control">
        <option value="45000" <%= registro.brutoEstimado === 45000 ? 'selected' : '' %>>45000 kg</option>
        <option value="52500" <%= registro.brutoEstimado === 52500 ? 'selected' : '' %>>52500 kg</option>
        <option value="55000" <%= registro.brutoEstimado === 55000 ? 'selected' : '' %>>55000 kg</option>
      </select>
    </div>
    <div class="col-md-4 form-group">
      <label>Tara (kg)</label>
      <input type="number" name="tara" class="form-control" value="<%= registro.tara || 0 %>" min="0">
    </div>
    <div class="col-md-4 form-group">
      <label>Bruto (kg)</label>
      <input type="number" name="bruto" class="form-control" value="<%= registro.bruto || 0 %>" min="0">
    </div>
  </div>

  <div class="row">
    <div class="col-md-4 form-group">
      <label>Cargo de</label>
      <select name="cargoDe" class="form-control" onchange="toggleCargo()">
        <option value="">Seleccione</option>
        <option value="SILOBOLSA"   <%= registro.cargoDe === 'SILOBOLSA'   ? 'selected' : '' %>>Silobolsa</option>
        <option value="CONTRATISTA" <%= registro.cargoDe === 'CONTRATISTA' ? 'selected' : '' %>>Contratista</option>
      </select>
    </div>
    <div class="col-md-4 form-group" id="silobolsaField" style="display:<%= registro.cargoDe === 'SILOBOLSA' ? 'block' : 'none' %>;">
      <label>Número Silobolsa</label>
      <input type="text" name="silobolsa" class="form-control" value="<%= registro.silobolsa || '' %>">
    </div>
    <div class="col-md-4 form-group" id="contratistaField" style="display:<%= registro.cargoDe === 'CONTRATISTA' ? 'block' : 'none' %>;">
      <label>Nombre Contratista</label>
      <input type="text" name="contratista" class="form-control" value="<%= registro.contratista || '' %>">
    </div>
  </div>

  <div class="form-group mt-2">
    <label>Comentarios</label>
    <textarea name="comentarios" class="form-control" rows="3"><%= registro.comentarios || '' %></textarea>
  </div>

  <button type="submit" class="btn btn-primary mt-3">Guardar Cambios</button>
  <a href="/tabla" class="btn btn-outline-secondary mt-3">Cancelar</a>
</form>

<script>
  function toggleSocio() {
    const c = document.querySelector('[name="cargaPara"]').value;
    document.getElementById('socioField').style.display = c === 'SOCIO' ? 'block' : 'none';
  }
  function toggleCargo() {
    const c = document.querySelector('[name="cargoDe"]').value;
    document.getElementById('silobolsaField').style.display   = c === 'SILOBOLSA'   ? 'block' : 'none';
    document.getElementById('contratistaField').style.display = c === 'CONTRATISTA' ? 'block' : 'none';
  }
</script>

<%- include('partials/footer') %>
