<%- include('partials/header') %>
<h1>Modificar Registro</h1>

<div class="alert alert-info">
  Solo se pueden editar: <strong>Patentes, Chofer, Tara, Cargo de, Silobolsa/Contratista y Comentarios</strong>. Disponible hasta 1 día después del registro de TARA FINAL.
</div>

<!-- Campos NO editables: solo lectura -->
<div class="card mb-3">
  <div class="card-body">
    <div class="row mb-2">
      <div class="col-md-3"><strong>ID Ticket:</strong> <%= registro.idTicket %></div>
      <div class="col-md-3"><strong>Fecha:</strong> <%= registro.fecha %></div>
      <div class="col-md-3"><strong>Usuario:</strong> <%= registro.usuario %></div>
      <div class="col-md-3"><strong>Pesada Para:</strong> <%= registro.pesadaPara %></div>
    </div>
    <div class="row">
      <div class="col-md-3"><strong>Campo:</strong> <%= registro.campo || '-' %></div>
      <div class="col-md-3"><strong>Grano:</strong> <%= registro.grano || '-' %></div>
      <div class="col-md-3"><strong>Lote:</strong> <%= registro.lote || '-' %></div>
      <div class="col-md-3"><strong>TARA FINAL:</strong> <%= registro.fechaTaraFinal || '-' %></div>
    </div>
  </div>
</div>

<!-- Formulario con campos editables -->
<form action="/modificar/<%= registro._id %>?_method=PUT" method="post" class="mt-3" autocomplete="off">
  <input type="hidden" name="_method" value="PUT">

  <div class="row">
    <div class="col-md-6 form-group">
      <label>Patentes</label>
      <input type="text" name="patentes" class="form-control" value="<%= registro.patentes || '' %>">
    </div>
    <div class="col-md-6 form-group">
      <label>Chofer</label>
      <input type="text" name="chofer" class="form-control" value="<%= registro.chofer || '' %>">
    </div>
  </div>

  <div class="row">
    <div class="col-md-4 form-group">
      <label>Tara (kg)</label>
      <input type="number" name="tara" class="form-control" value="<%= registro.tara || 0 %>" min="0">
    </div>
    <div class="col-md-4 form-group">
      <label>Cargo de</label>
      <select name="cargoDe" class="form-control" onchange="toggleCargo()">
        <option value="">Seleccione</option>
        <option value="SILOBOLSA"   <%= registro.cargoDe === 'SILOBOLSA'   ? 'selected' : '' %>>Silobolsa</option>
        <option value="CONTRATISTA" <%= registro.cargoDe === 'CONTRATISTA' ? 'selected' : '' %>>Contratista</option>
      </select>
    </div>
    <div class="col-md-4 form-group" id="silobolsaField" style="display:<%= registro.cargoDe === 'SILOBOLSA' ? 'block' : 'none' %>;">
      <label>Número Silobolsa</label>
      <input type="text" name="silobolsa" class="form-control" value="<%= registro.silobolsa || '' %>">
    </div>
    <div class="col-md-4 form-group" id="contratistaField" style="display:<%= registro.cargoDe === 'CONTRATISTA' ? 'block' : 'none' %>;">
      <label>Nombre Contratista</label>
      <select name="contratista" id="contratista" class="form-control">
        <option value="">Seleccione un contratista</option>
        <% Object.keys(contratistas || {}).forEach(nombre => { %>
          <option value="<%= nombre %>" <%= registro.contratista === nombre ? 'selected' : '' %>><%= nombre %></option>
        <% }) %>
      </select>
    </div>
  </div>

  <div class="row">
    <div class="col-md-4 form-group" id="tractorField" style="display:<%= registro.cargoDe === 'CONTRATISTA' ? 'block' : 'none' %>;">
      <label>Tractor</label>
      <select name="tractor" id="tractor" class="form-control">
        <option value="">Seleccione un tractor</option>
        <% if (registro.cargoDe === 'CONTRATISTA' && registro.contratista && contratistas && contratistas[registro.contratista]) { %>
          <% contratistas[registro.contratista].forEach(t => { %>
            <option value="<%= t %>" <%= registro.tractor === t ? 'selected' : '' %>><%= t %></option>
          <% }) %>
        <% } %>
      </select>
    </div>
  </div>

  <div class="form-group mt-2">
    <label>Comentarios</label>
    <textarea name="comentarios" class="form-control" rows="3"><%= registro.comentarios || '' %></textarea>
  </div>

  <button type="submit" class="btn btn-primary mt-3">Guardar Cambios</button>
  <a href="/tabla" class="btn btn-outline-secondary mt-3">Cancelar</a>
</form>

<script>
  window.contratistas = <%- JSON.stringify(contratistas || {}) %>;

  function toggleCargo() {
    const c = document.querySelector('[name="cargoDe"]').value;
    document.getElementById('silobolsaField').style.display   = c === 'SILOBOLSA'   ? 'block' : 'none';
    document.getElementById('contratistaField').style.display = c === 'CONTRATISTA' ? 'block' : 'none';
    document.getElementById('tractorField').style.display     = c === 'CONTRATISTA' ? 'block' : 'none';
  }

  // Al cambiar contratista, repoblar tractores
  document.getElementById('contratista')?.addEventListener('change', function () {
    const tractorSel = document.getElementById('tractor');
    tractorSel.innerHTML = '<option value="">Seleccione un tractor</option>';
    const lista = window.contratistas[this.value] || [];
    lista.forEach(t => {
      const op = document.createElement('option');
      op.text = op.value = t;
      tractorSel.appendChild(op);
    });
  });
</script>

<%- include('partials/footer') %>
